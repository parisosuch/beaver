---
import "../styles/global.css";
import LoginView from "../components/login-view";
import { getAdminUsers } from "@/lib/beaver/user";

// If no admin user exists, redirect to onboarding
const adminUsers = await getAdminUsers();

if (adminUsers.length === 0) {
  return Astro.redirect("/onboarding");
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/beaver.png" />
    <title>Beaver - Sign In</title>
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme") || "system";
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (stored === "dark" || (stored === "system" && prefersDark)) {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
  </head>
  <body>
    <LoginView client:only="react" />
  </body>
</html>
