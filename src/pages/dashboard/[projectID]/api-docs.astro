                  <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400">string</td>
                  <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400">Dropdown (≤ 20 distinct values) or free-text input</td>
                </tr>
                <tr class="hover:bg-gray-50 dark:hover:bg-white/5 transition-colors">
                  <td class="px-4 py-3"><code class="text-sm bg-gray-100 dark:bg-white/10 px-2 py-0.5 rounded">99.99</code></td>
