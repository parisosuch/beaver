---
import Layout from "@/layouts/layout.astro";
import EventFeed from "@/components/event-feed";
import { getChannel } from "@/lib/beaver/channel";
import { getUserByUsername } from "@/lib/beaver/user";
import { getUserProjectRole } from "@/lib/beaver/project-member";

const { projectID, channelID } = Astro.params;
const user = Astro.locals.user!;
const dbUser = await getUserByUsername(user.userName);

const url = new URL(Astro.request.url);
const searchParams = url.searchParams;

const title = searchParams.get("title");
const object = searchParams.get("object");
const action = searchParams.get("action");
const startDate = searchParams.get("startDate");
const endDate = searchParams.get("endDate");
const tags = searchParams.get("tags");
const sortBy = searchParams.get("sortBy");
const sortOrder = searchParams.get("sortOrder");

const channel = await getChannel(parseInt(channelID!));

const userRole = user.isAdmin
  ? "owner"
  : await getUserProjectRole(parseInt(projectID!), user.id);
---

<Layout projectID={projectID!}>
  <EventFeed
    client:load
    type="channel"
    projectID={parseInt(projectID!)}
    channel={channel}
    userRole={userRole}
    title={title}
    object={object}
    action={action}
    startDate={startDate}
    endDate={endDate}
    tags={tags}
    sortBy={sortBy}
    sortOrder={sortOrder}
    compact={dbUser?.compactMode ?? false}
  />
</Layout>
